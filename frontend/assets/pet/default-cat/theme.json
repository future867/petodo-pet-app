{
  "name": "default-cat",
  "displayName": "线条小猫",
  "defaultState": "idle",
  "states": {
    "idle": {
      "type": "frames",
      "path": "idle",
      "fps": 6,
      "loop": true
    },
    "focus": {
      "type": "frames",
      "path": "focus",
      "fps": 6,
      "loop": true
    },
    "rest": {
      "type": "frames",
      "path": "rest",
      "fps": 6,
      "loop": true
    },
    "hungry": {
      "type": "frames",
      "path": "hungry",
      "fps": 6,
      "loop": true
    },
    "sleep": {
      "type": "frames",
      "path": "sleep",
      "fps": 4,
      "loop": true
    },
    "angry": {
      "type": "frames",
      "path": "angry",
      "fps": 6,
      "loop": true,
      "fallbackTo": "hungry"
    },
    "drag": {
      "type": "single",
      "path": "drag/drag.png",
      "fallbackTo": "idle"
    },
    "tap": {
      "type": "frames",
      "path": "tap",
      "fps": 8,
      "loop": false,
      "fallbackTo": "idle"
    }
  }
}
