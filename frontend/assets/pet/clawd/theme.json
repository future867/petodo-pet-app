{
  "name": "clawd",
  "displayName": "Clawd",
  "defaultState": "idle",
  "states": {
    "idle": {
      "type": "image",
      "path": "gif/clawd-idle.gif",
      "loop": true
    },
    "focus": {
      "_comment": "focus is Petodo's Pomodoro focus state. Visually it reuses Clawd's typing animation.",
      "type": "image",
      "path": "gif/clawd-typing.gif",
      "loop": true,
      "fallbackTo": "idle"
    },
    "rest": {
      "type": "image",
      "path": "gif/clawd-idle-reading.gif",
      "loop": true,
      "fallbackTo": "idle"
    },
    "happy": {
      "type": "image",
      "path": "gif/clawd-happy.gif",
      "loop": false,
      "duration": 3000,
      "fallbackTo": "idle"
    },
    "sleep": {
      "type": "image",
      "path": "gif/clawd-sleeping.gif",
      "loop": true,
      "fallbackTo": "idle"
    },
    "hungry_light": {
      "type": "image",
      "path": "gif/clawd-thinking.gif",
      "loop": true,
      "bubble": "food?",
      "fallbackTo": "idle"
    },
    "hungry": {
      "type": "image",
      "path": "gif/clawd-thinking.gif",
      "loop": true,
      "bubble": "food?",
      "fallbackTo": "idle"
    },
    "hungry_medium": {
      "type": "image",
      "path": "gif/clawd-error.gif",
      "loop": true,
      "fallbackTo": "hungry_light"
    },
    "angry": {
      "type": "image",
      "path": "gif/clawd-error.gif",
      "loop": true,
      "movement": "run-top",
      "fallbackTo": "hungry_medium"
    },
    "eating": {
      "type": "image",
      "path": "gif/clawd-thinking.gif",
      "loop": true,
      "bubble": "eating...",
      "fallbackTo": "idle"
    },
    "finished_eating": {
      "type": "image",
      "path": "gif/clawd-juggling.gif",
      "loop": false,
      "duration": 3000,
      "fallbackTo": "idle"
    },
    "drag": {
      "type": "image",
      "path": "drag/clawd-react-drag.svg",
      "loop": false,
      "duration": 700,
      "fallbackTo": "idle"
    },
    "tap": {
      "type": "image",
      "path": "tap/clawd-react-left.svg",
      "loop": false,
      "duration": 650,
      "fallbackTo": "idle"
    }
  },
  "attribution": {
    "source": "clawd-on-desk",
    "note": "Clawd theme assets are used with authorization for local coursework demo. Character and asset rights remain with the original rights holder."
  }
}
